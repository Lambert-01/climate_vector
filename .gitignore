# ─── Data (raw sensitive files) ───────────────────────────────────────────────
data/raw/*.xls
data/raw/*.xlsx
data/raw/*.csv
data/external/era5_land/raw/
data/external/population/
data/external/osm/

# ─── Large raster / GIS files ─────────────────────────────────────────────────
