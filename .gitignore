*.tiff
*.zip
*.nc
*.h5
*.hdf5

# ─── Outputs (generated) ──────────────────────────────────────────────────────
outputs/reports/
outputs/tables/
data/interim/
data/processed/

# Deployment-safe current-data extracts.
# Raw Excel remains ignored; these CSVs are needed by the Render API.
!outputs/
!outputs/tables/
!outputs/tables/*.csv
!data/processed/
!data/processed/*.csv
data/processed/field_verifications.json
!data/sites/
!data/sites/*.csv

# ─── Models ───────────────────────────────────────────────────────────────────
models/registry/
models/approved/
*.pkl
*.joblib
*.h5
*.pt
*.pth

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
