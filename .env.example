# Copy this file to .env and fill in your values.

DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-2.aws.neon.tech/climate_vector?sslmode=require
DATABASE_SYNC_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/climate_vector?sslmode=require

API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-long-random-secret-key
OPERATOR_API_KEY=change-this-pilot-operator-key
API_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
BOOTSTRAP_ADMIN_EMAIL=admin@example.org
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
BOOTSTRAP_ADMIN_NAME=Platform Administrator
SENTRY_DSN=
MAX_UPLOAD_MB=5

VITE_API_BASE=http://localhost:8000/api

# Copernicus Climate Data Store / ERA5-Land.
# Keep the real key only in .env or hosting secrets. Do not commit it.
CDS_API_URL=https://cds.climate.copernicus.eu/api
CDS_API_KEY=replace-with-cds-personal-access-token
CDS_ERA5_YEAR=2024
CDS_ERA5_MONTH=01
CDS_ERA5_VARIABLES=2m_dewpoint_temperature,2m_temperature,runoff,surface_runoff,total_precipitation

PROJECT_NAME=DengueEW-GL
PROJECT_ENV=development
